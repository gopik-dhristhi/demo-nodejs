* {
  margin: 0;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}

body {
  height: 100vh;
  background: radial-gradient(ellipse at bottom, #0b0c2a 0%, #000000 100%);
  position: relative;
  font-family: sans-serif;
}

/* Stars */
.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle linear infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 1; }
}

/* Nebula */
.nebula {
  position: absolute;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(138,43,226,0.4), transparent 70%);
  filter: blur(100px);
  animation: moveNebula 40s infinite alternate ease-in-out;
}

.nebula2 {
  background: radial-gradient(circle, rgba(0,191,255,0.3), transparent 70%);
  top: 20%;
  left: 60%;
}

@keyframes moveNebula {
  from { transform: translate(0, 0) scale(1); }
  to { transform: translate(-100px, 50px) scale(1.2); }
}

/* Milky Way band */
.milkyway {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120%;
  height: 300px;
  transform: translate(-50%, -50%) rotate(-20deg);
  background: radial-gradient(ellipse at center,
    rgba(255,255,255,0.15) 0%,
    rgba(255,255,255,0.05) 40%,
    transparent 70%);
  filter: blur(30px);
  opacity: 0.7;
}

/* Bottom Button */
.bottom-btn {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  padding: 12px 30px;
  font-size: 16px;
  color: white;
  text-decoration: none;
  background: rgba(30,144,255,0.7);
  border: 2px solid rgba(255,255,255,0.6);
  border-radius: 30px;
  cursor: pointer;
  backdrop-filter: blur(5px);
  transition: 0.3s;
}

.bottom-btn:hover {
  background: rgba(30,144,255,0.9);
  box-shadow: 0 0 15px rgba(255,255,255,0.6);
}